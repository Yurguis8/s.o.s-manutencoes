# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# URL pública do site (frontend) — usada no redirect pós-pagamento
APP_URL="https://seu-site.vercel.app"

# URL pública do backend — usada no webhook do Mercado Pago
BACKEND_URL="https://sos-manutencoes-api.onrender.com"

# Mercado Pago Credentials (produção: APP_USR-...)
MERCADO_PAGO_PUBLIC_KEY="TEST-XXXX"
MERCADO_PAGO_ACCESS_TOKEN="TEST-XXXX"

# Chave secreta do webhook (Mercado Pago → Suas integrações → Webhooks)
MERCADO_PAGO_WEBHOOK_SECRET=""

# Server Config
PORT=3001

# PostgreSQL (Supabase)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.tjtobrgskbqrdpebzbgk.supabase.co:5432/postgres"

